{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "debug",
      "displayName": "Host Debug",
      "description": "Ordinary debug build for the host",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_TESTING": "ON",
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++"
      }
    },
    {
      "name": "debug-gcc-snapshot",
      "displayName": "Host Debug (gcc-snapshot)",
      "description": "Ordinary debug build for the host (gcc-snapshot)",
      "binaryDir": "${sourceDir}/build-gcc-snapshot",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_TESTING": "ON",
        "CMAKE_C_COMPILER": "/usr/lib/gcc-snapshot/bin/gcc",
        "CMAKE_CXX_COMPILER": "/usr/lib/gcc-snapshot/bin/g++"
      }
    },
    {
      "name": "android-arm64-v8a",
      "displayName": "Android JNI Library (arm64-v8a)",
      "description": "Build Android JNI shared library (arm64-v8a)",
      "binaryDir": "${sourceDir}/build-android-arm64-v8a",
      "toolchainFile": "$env{HOME}/android-sdk/ndk/30.0.14904198/build/cmake/android.toolchain.cmake",
      "cacheVariables": {
        "GREAT_HOLE_BUILD_ANDROID": "ON",
        "ANDROID_ABI": "arm64-v8a",
        "ANDROID_PLATFORM": "android-26",
        "BUILD_TESTING": "OFF"
      }
    },
    {
      "name": "android-x86_64",
      "displayName": "Android JNI Library (x86_64)",
      "description": "Build Android JNI shared library (x86_64)",
      "binaryDir": "${sourceDir}/build-android-x86_64",
      "toolchainFile": "$env{HOME}/android-sdk/ndk/30.0.14904198/build/cmake/android.toolchain.cmake",
      "cacheVariables": {
        "GREAT_HOLE_BUILD_ANDROID": "ON",
        "ANDROID_ABI": "x86_64",
        "ANDROID_PLATFORM": "android-26",
        "BUILD_TESTING": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "gcc-build",
      "jobs": 8
    },
    {
      "name": "clang-build",
      "jobs": 16
    },
    {
      "name": "build-debug",
      "configurePreset": "debug",
      "inherits": "clang-build"
    },
    {
      "name": "build-debug-gcc-snapshot",
      "configurePreset": "debug-gcc-snapshot",
      "inherits": "gcc-build"
    },
    {
      "name": "build-android-arm64-v8a",
      "configurePreset": "android-arm64-v8a",
      "inherits": "clang-build"
    },
    {
      "name": "build-android-x86_64",
      "configurePreset": "android-x86_64",
      "inherits": "clang-build"
    }
  ]
}