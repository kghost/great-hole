{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 20, "patch": 0 },
  "configurePresets": [
    {
      "name": "configure-debug",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug", "CMAKE_C_COMPILER": "clang", "CMAKE_CXX_COMPILER": "clang++" }
    },
    {
      "name": "configure-debug-tidy",
      "inherits": "configure-debug",
      "binaryDir": "${sourceDir}/build-tidy",
      "cacheVariables": { "BUILD_WITH_CLANG_TIDY": "ON" }
    },
    {
      "name": "configure-debug-gcc-14",
      "binaryDir": "${sourceDir}/build-gcc-14",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug", "CMAKE_C_COMPILER": "/usr/bin/gcc-14", "CMAKE_CXX_COMPILER": "/usr/bin/g++-14" }
    },
    {
      "name": "configure-debug-gcc-snapshot",
      "binaryDir": "${sourceDir}/build-gcc-snapshot",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug", "CMAKE_C_COMPILER": "/usr/lib/gcc-snapshot/bin/gcc", "CMAKE_CXX_COMPILER": "/usr/lib/gcc-snapshot/bin/g++" }
    },
    {
      "name": "configure-windows-debug-msvc",
      "binaryDir": "${sourceDir}/build-windows-msvc",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug", "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake" },
      "environment": { "ASAN_OPTIONS": "detect_container_overflow=0" }
    },
    {
      "name": "configure-windows-debug-ninja",
      "inherits": "configure-windows-debug-msvc",
      "binaryDir": "${sourceDir}/build",
      "generator": "Ninja"
    },
    {
      "name": "configure-android-base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build-${presetName}",
      "toolchainFile": "$env{HOME}/android-sdk/ndk/30.0.14904198/build/cmake/android.toolchain.cmake",
      "cacheVariables": { "ANDROID_PLATFORM": "android-26", "BUILD_TESTING": "OFF" }
    },
    {
      "name": "configure-android-arm64-v8a-debug",
      "inherits": "configure-android-base",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug", "ANDROID_ABI": "arm64-v8a" }
    },
    {
      "name": "configure-android-x86_64-debug",
      "inherits": "configure-android-base",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug", "ANDROID_ABI": "x86_64" }
    },
    {
      "name": "configure-android-arm64-v8a-release",
      "inherits": "configure-android-base",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release", "ANDROID_ABI": "arm64-v8a" }
    },
    {
      "name": "configure-android-x86_64-release",
      "inherits": "configure-android-base",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release", "ANDROID_ABI": "x86_64" }
    }
  ],
  "buildPresets": [
    { "name": "build-debug", "configurePreset": "configure-debug", "jobs": 16 },
    { "name": "build-debug-tidy", "configurePreset": "configure-debug-tidy", "jobs": 16 },
    { "name": "build-debug-gcc-14", "configurePreset": "configure-debug-gcc-14", "jobs": 8 },
    { "name": "build-debug-gcc-snapshot", "configurePreset": "configure-debug-gcc-snapshot", "jobs": 8 },
    { "name": "build-windows-debug-msvc", "configurePreset": "configure-windows-debug-msvc", "jobs": 8 },
    { "name": "build-windows-debug-ninja", "configurePreset": "configure-windows-debug-ninja", "jobs": 8 },
    { "name": "build-android-arm64-v8a-debug", "configurePreset": "configure-android-arm64-v8a-debug", "jobs": 16 },
    { "name": "build-android-x86_64-debug", "configurePreset": "configure-android-x86_64-debug", "jobs": 16 },
    { "name": "build-android-arm64-v8a-release", "configurePreset": "configure-android-arm64-v8a-release", "jobs": 16 },
    { "name": "build-android-x86_64-release", "configurePreset": "configure-android-x86_64-release", "jobs": 16 }
  ],
  "testPresets": [
    { "name": "test-debug", "configurePreset": "configure-debug" },
    { "name": "test-debug-gcc-14", "configurePreset": "configure-debug-gcc-14" },
    { "name": "test-debug-gcc-snapshot", "configurePreset": "configure-debug-gcc-snapshot" },
    { "name": "test-windows-debug-msvc", "configurePreset": "configure-windows-debug-msvc", "environment": { "ASAN_OPTIONS": "detect_container_overflow=0" } },
    { "name": "test-windows-debug-ninja", "configurePreset": "configure-windows-debug-ninja", "environment": { "ASAN_OPTIONS": "detect_container_overflow=0" } }
  ],
  "workflowPresets": [
    {
      "name": "debug",
      "steps": [
        { "type": "configure", "name": "configure-debug" },
        { "type": "build", "name": "build-debug" },
        { "type": "test", "name": "test-debug" }
      ]
    },
    {
      "name": "debug-gcc-14",
      "steps": [
        { "type": "configure", "name": "configure-debug-gcc-14" },
        { "type": "build", "name": "build-debug-gcc-14" },
        { "type": "test", "name": "test-debug-gcc-14" }
      ]
    },
    {
      "name": "debug-gcc-snapshot",
      "steps": [
        { "type": "configure", "name": "configure-debug-gcc-snapshot" },
        { "type": "build", "name": "build-debug-gcc-snapshot" },
        { "type": "test", "name": "test-debug-gcc-snapshot" }
      ]
    },
    {
      "name": "windows-debug-msvc",
      "steps": [
        { "type": "configure", "name": "configure-windows-debug-msvc" },
        { "type": "build", "name": "build-windows-debug-msvc" },
        { "type": "test", "name": "test-windows-debug-msvc" }
      ]
    },
    {
      "name": "windows-debug-ninja",
      "steps": [
        { "type": "configure", "name": "configure-windows-debug-ninja" },
        { "type": "build", "name": "build-windows-debug-ninja" },
        { "type": "test", "name": "test-windows-debug-ninja" }
      ]
    },
    {
      "name": "android-arm64-v8a-debug",
      "steps": [
        { "type": "configure", "name": "configure-android-arm64-v8a-debug" },
        { "type": "build", "name": "build-android-arm64-v8a-debug" }
      ]
    },
    {
      "name": "android-x86_64-debug",
      "steps": [
        { "type": "configure", "name": "configure-android-x86_64-debug" },
        { "type": "build", "name": "build-android-x86_64-debug" }
      ]
    },
    {
      "name": "android-arm64-v8a-release",
      "steps": [
        { "type": "configure", "name": "configure-android-arm64-v8a-release" },
        { "type": "build", "name": "build-android-arm64-v8a-release" }
      ]
    },
    {
      "name": "android-x86_64-release",
      "steps": [
        { "type": "configure", "name": "configure-android-x86_64-release" },
        { "type": "build", "name": "build-android-x86_64-release" }
      ]
    }
  ]
}