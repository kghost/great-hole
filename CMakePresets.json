{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "debug",
      "displayName": "Host Debug",
      "description": "Ordinary debug build for the host",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_TESTING": "ON"
      }
    },
    {
      "name": "android",
      "displayName": "Android JNI Library",
      "description": "Build Android JNI shared library",
      "binaryDir": "${sourceDir}/build-android",
      "toolchainFile": "$env{HOME}/android-sdk/ndk/30.0.14904198/build/cmake/android.toolchain.cmake",
      "cacheVariables": {
        "GREAT_HOLE_BUILD_ANDROID": "ON",
        "ANDROID_ABI": "arm64-v8a",
        "ANDROID_PLATFORM": "android-26",
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_TESTING": "OFF"
      }
    }
  ]
}