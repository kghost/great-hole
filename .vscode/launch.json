{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "lldb-dap",
            "request": "launch",
            "name": "launch great-hole",
            "program": "${workspaceFolder}/build/src/great-hole",
            "console": "integratedTerminal",
            "initCommands": [
                "process handle SIGINT --stop false --notify false --pass true"
            ],
            "args": [
                "example.lua"
            ],
            "cwd": "${workspaceFolder}",
            "sourceMap": [
                [
                    ".",
                    "${workspaceFolder}"
                ]
            ]
        },
        {
            "type": "lldb-dap",
            "request": "launch",
            "name": "launch test",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "program": "${cmake.testProgram}",
            "args": [
                "${cmake.testArgs}"
            ],
            "sourceMap": [
                [
                    ".",
                    "${workspaceFolder}"
                ]
            ]
        }
    ]
}